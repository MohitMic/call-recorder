<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/dark_card">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/playback_title"
            android:textColor="@color/text_primary_dark"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Now-playing card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="28dp"
        android:paddingBottom="20dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/dark_card">

        <!-- Circular avatar -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/textPlaybackAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_circle_pink" />

        </FrameLayout>

        <!-- Caller name -->
        <TextView
            android:id="@+id/playbackNowPlaying"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/playback_none"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_dark"
            android:gravity="center"
            android:ellipsize="end"
            android:singleLine="true" />

        <!-- Sub-text: direction + duration -->
        <TextView
            android:id="@+id/textPlaybackSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textSize="13sp"
            android:textColor="@color/text_secondary_dark" />

    </LinearLayout>

    <!-- Seek + times -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="8dp">

        <SeekBar
            android:id="@+id/playbackSeek"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:progressTint="@color/pink"
            android:thumbTint="@color/pink" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/textPlaybackCurrentTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="@color/text_secondary_dark"
                android:text="0:00" />

            <TextView
                android:id="@+id/textPlaybackTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary_dark"
                android:text="0:00" />

        </LinearLayout>

    </LinearLayout>

    <!-- Play/Pause button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:id="@+id/playbackPlayPause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_pink"
            android:clickable="true"
            android:focusable="true"
            android:enabled="false">

            <ImageView
                android:id="@+id/iconPlayPause"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:contentDescription="Play or pause" />

        </FrameLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dark_divider" />

    <!-- Other recordings header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:text="Other recordings"
        android:textSize="12sp"
        android:textColor="@color/text_secondary_dark"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <!-- List of recordings -->
    <ListView
        android:id="@+id/playbackList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/dark_divider"
        android:dividerHeight="1dp" />

</LinearLayout>
